        <mxCell id="step1" value="1. parse RESP&#xa;(resp.rs)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="260" y="120" width="280" height="50" as="geometry" />
        </mxCell>

