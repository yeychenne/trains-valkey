        <!-- Invariants box -->
        <mxCell id="inv" value="The four invariants&#xa;&#xa;1. Total order on writes&#xa;   (uniform delivery, TRAINS)&#xa;&#xa;2. At-most-once apply&#xa;   per-replica (origin, request_id) dedup&#xa;&#xa;3. Deterministic effect&#xa;   non-det resolved at origin before broadcast&#xa;&#xa;4. Crash masking&#xa;   confirmed permanent crash triggers&#xa;   view change &#x2192; ring re-forms" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;align=left;fontSize=10;verticalAlign=top;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
