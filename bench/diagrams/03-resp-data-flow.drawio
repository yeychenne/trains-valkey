          <mxGeometry x="260" y="180" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="step3" value="3. effect resolver  (origin-side)&#xa;non-deterministic mutations  &#x2192;  deterministic effect&#xa;SPOP key   &#x2192;   SREM key m&#xa;INCRBYFLOAT k v  &#x2192;  SET k (x+v) formatted %.17g" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="260" y="240" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="step4" value="4. wrap as WriteOp&#xa;(origin, request_id, effect)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="260" y="330" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="step5" value="5. TRAINS oBroadcast  (trains-core via trains-net)&#xa;ring &#x2014; uniform total order delivery" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="260" y="390" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="step6" value="6. wait for delivery on self, then apply" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;fontSize=10" vertex="1" parent="1">
