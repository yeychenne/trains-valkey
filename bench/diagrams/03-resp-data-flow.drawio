        <mxCell id="title" value="RESP write path:  classify &#x2192; resolve &#x2192; broadcast &#x2192; deliver-in-order &#x2192; apply" style="text;html=1;align=center;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="950" height="30" as="geometry" />
        </mxCell>

