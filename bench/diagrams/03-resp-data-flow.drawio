        <mxCell id="client" value="RESP client&#xa;SET k v&#xa;SPOP s" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="130" height="80" as="geometry" />
        </mxCell>
