        <!-- T2 — connector_loop sees close (PR-RD-9) -->
        <mxCell id="t2" value="T2  PR-RD-9: connector_loop reads TLS stream, sees Close_notify / EOF&#xa;exits writer, force_reconnect, fails on connect" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="440" y="340" width="450" height="40" as="geometry" />
        </mxCell>

