        <!-- T1 — node-1 writes block at TCP_USER_TIMEOUT -->
        <mxCell id="t1" value="T1 + ~3s  PR-RD-6: kernel TCP_USER_TIMEOUT fires, ring socket force-closes" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=9" vertex="1" parent="1">
