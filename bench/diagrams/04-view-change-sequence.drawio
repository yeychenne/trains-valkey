        <!-- T8 — proxy resumes serving writes -->
        <mxCell id="t8" value="T8  surviving proxies resume serving writes in the new view&#xa;(observed MTTR ~10s in EC2; PR-RD-6 + PR-RD-8 + PR-RD-9 wall-clock 45.30 s end-to-end for the during-window E1-v2 run)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="710" width="800" height="50" as="geometry" />
        </mxCell>

        <!-- Footnote box -->
        <mxCell id="foot" value="Failure-detection paths (PR-RD-6/8/9 stacked):&#xa;• kernel level — TCP_USER_TIMEOUT=3s force-closes the socket&#xa;• application level — abort() also closes accepted-conn tasks (no leaked writers)&#xa;• connector level — connector reads the TLS stream, sees Close_notify when peer dies idle&#xa;Pre-stack symptom (E1, May-26 morning): writes hung 5 min into kernel buffer, no view-change.&#xa;Post-stack result (E1-v2, May-26 PM): 2000/2000 acked through the masked window." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;align=left;fontSize=10;verticalAlign=top;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="100" y="780" width="900" height="100" as="geometry" />
        </mxCell>

